rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Demo posture: the command center is a public read-only view.
    // All writes go through server routes using the Admin SDK (which
    // bypasses rules), so clients can never write directly.
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
